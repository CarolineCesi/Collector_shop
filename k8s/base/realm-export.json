{
  "realm": "collector-shop",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Regular user"
      },
      {
        "name": "admin",
        "description": "Admin user"
      }
    ]
  },
  "defaultRoles": [
    "user"
  ],
  "clients": [
    {
      "clientId": "collector-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://localhost:3000/*",
        "http://collector-shop.local/*",
        "http://collector-shop.local/profile",
        "http://collector-shop.local",
        "https://collector-shop-dev/*",
        "https://collector-shop-dev/profile",
        "https://collector-shop-dev"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:3000",
        "http://collector-shop.local",
        "https://collector-shop-dev",
        "*"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ]
    }
  ],
  "users": [
    {
      "username": "alex",
      "email": "alex@example.com",
      "enabled": true,
      "firstName": "Alex",
      "lastName": "Collector",
      "credentials": [
        {
          "type": "password",
          "value": "changeme",
          "temporary": true
        }
      ],
      "realmRoles": [
        "user"
      ],
      "attributes": {
        "avatar": [
          "https://images.unsplash.com/photo-1704726135027-9c6f034cfa41?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHx1c2VyJTIwYXZhdGFyJTIwcG9ydHJhaXR8ZW58MXx8fHwxNzcxODUyMjg4fDA&ixlib=rb-4.1.0&q=80&w=1080"
        ]
      }
    }
  ]
}